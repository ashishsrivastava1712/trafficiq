{
  "version": 2,
  "builds": [
    {
      "src": "frontend.html",
      "use": "@vercel/static"
    },
    {
      "src": "map_page.html", 
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/frontend.html"
    },
    {
      "src": "/map",
      "dest": "/map_page.html"
    }
  ]
}