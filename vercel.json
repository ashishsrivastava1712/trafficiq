{
  "version": 2,
  "builds": [
    {"src": "*.html", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/", "dest": "/frontend.html"},
    {"src": "/map", "dest": "/map_page.html"},
    {"src": "/eda", "dest": "/eda.html"},
    {"src": "/features", "dest": "/features.html"},
    {"src": "/evaluation", "dest": "/evaluation.html"},
    {"src": "/(.*)", "dest": "/$1"}
  ]
}